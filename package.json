{
  "name": "quadtodo",
  "version": "0.1.0",
  "description": "Local four-quadrant todo CLI with embedded Claude Code / Codex terminal",
  "license": "MIT",
  "author": "LIUZHENHUA521",
  "keywords": [
    "cli",
    "todo",
    "quadrant",
    "claude-code",
    "codex",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LIUZHENHUA521/quadtodo.git"
  },
  "homepage": "https://github.com/LIUZHENHUA521/quadtodo#readme",
  "bugs": {
    "url": "https://github.com/LIUZHENHUA521/quadtodo/issues"
  },
  "type": "module",
  "bin": {
    "quadtodo": "src/cli.js"
  },
  "files": [
    "src",
    "dist-web",
    "dist-web/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js start",
    "start:expose": "node src/cli.js start --expose",
    "stop": "node src/cli.js stop",
    "status": "node src/cli.js status",
    "doctor": "node src/cli.js doctor",
    "config": "node src/cli.js config",
    "mira:proxy": "cd mira-proxy && node server.js",
    "claude:mira": "./claude-mira.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "telegram:setup-menu": "node scripts/setup-telegram-commands.js",
    "telegram:clear-menu": "node scripts/setup-telegram-commands.js --clear",
    "build": "npm run build:web",
    "build:web": "cd web && npm run build",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "https-proxy-agent": "^9.0.0",
    "node-pty": "1.0.0",
    "open": "^10.1.0",
    "pidusage": "^4.0.1",
    "telegramify-markdown": "^1.3.3",
    "undici": "^7.25.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
