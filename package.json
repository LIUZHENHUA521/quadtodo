{
  "name": "agentquad",
  "version": "0.2.0",
  "description": "AgentQuad — local four-quadrant AI task scheduler with embedded Claude Code / Codex terminals",
  "license": "MIT",
  "author": "LIUZHENHUA521",
  "keywords": [
    "cli",
    "agent",
    "agentquad",
    "todo",
    "quadrant",
    "claude-code",
    "codex",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LIUZHENHUA521/agentquad.git"
  },
  "homepage": "https://github.com/LIUZHENHUA521/agentquad#readme",
  "bugs": {
    "url": "https://github.com/LIUZHENHUA521/agentquad/issues"
  },
  "type": "module",
  "bin": {
    "agentquad": "src/cli.js",
    "quadtodo": "src/cli.js"
  },
  "files": [
    "src",
    "dist-web",
    "dist-web/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js start",
    "start:expose": "node src/cli.js start --expose",
    "stop": "node src/cli.js stop",
    "status": "node src/cli.js status",
    "doctor": "node src/cli.js doctor",
    "config": "node src/cli.js config",
    "mira:proxy": "cd mira-proxy && node server.js",
    "claude:mira": "./claude-mira.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "telegram:setup-menu": "node scripts/setup-telegram-commands.js",
    "telegram:clear-menu": "node scripts/setup-telegram-commands.js --clear",
    "setup": "npm install && npm --prefix web install",
    "build": "npm run ensure-web-deps && npm run build:web",
    "build:web": "cd web && npm run build",
    "build:all": "npm run setup && npm run build",
    "clean": "rm -rf node_modules web/node_modules dist-web web/dist",
    "ensure-web-deps": "node scripts/ensure-web-deps.js",
    "prepack": "npm run ensure-web-deps && npm run build:web",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "https-proxy-agent": "^9.0.0",
    "node-pty": "^1.1.0-beta22",
    "open": "^10.1.0",
    "pidusage": "^4.0.1",
    "telegramify-markdown": "^1.3.3",
    "undici": "^7.25.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ]
}
