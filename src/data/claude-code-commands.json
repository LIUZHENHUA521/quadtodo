{
  "_comment": "Curated list of Claude Code built-in slash commands for Telegram per-chat menu. Telegram requires names to be [a-z0-9_]+ — commands with hyphens (install-github-app, add-dir, output-style, pr-comments, release-notes, terminal-setup, setup-agents, migrate-installer) cannot be registered and are intentionally omitted. Add or remove entries as Claude Code evolves.",
  "_source": "Claude Code v2.1.x — extracted from binary strings + official docs (2026-05)",
  "_telegram_constraints": {
    "name_regex": "^[a-z][a-z0-9_]{0,31}$",
    "description_max_len": 256,
    "max_commands": 100
  },
  "commands": [
    { "command": "help",         "description": "Show available commands" },
    { "command": "clear",        "description": "Clear conversation history" },
    { "command": "compact",      "description": "Summarize and clear context to save tokens" },
    { "command": "cost",         "description": "Show token cost for this session" },
    { "command": "usage",        "description": "Show current usage and rate limit status" },
    { "command": "model",        "description": "Switch model (sonnet / opus / haiku)" },
    { "command": "effort",       "description": "Set effort level (low / medium / high / xhigh / max)" },
    { "command": "fast",         "description": "Toggle Fast mode (Opus 4.6, faster output)" },
    { "command": "login",        "description": "Login to Claude" },
    { "command": "logout",       "description": "Logout" },
    { "command": "config",       "description": "Show or edit configuration" },
    { "command": "init",         "description": "Initialize CLAUDE.md for the project" },
    { "command": "memory",       "description": "View or edit Claude memory" },
    { "command": "status",       "description": "Show current session status" },
    { "command": "doctor",       "description": "Run diagnostics (config / install health check)" },
    { "command": "bug",          "description": "Report a bug" },
    { "command": "feedback",     "description": "Send feedback to Anthropic" },
    { "command": "exit",         "description": "Exit Claude Code" },
    { "command": "quit",         "description": "Exit Claude Code (alias)" },
    { "command": "permissions",  "description": "Manage permission rules" },
    { "command": "agents",       "description": "Manage subagents" },
    { "command": "mcp",          "description": "Manage MCP servers" },
    { "command": "hooks",        "description": "Manage Claude Code hooks" },
    { "command": "skills",       "description": "List available skills" },
    { "command": "skill",        "description": "Run a skill by name" },
    { "command": "review",       "description": "Review code" },
    { "command": "vim",          "description": "Toggle vim mode for the input" },
    { "command": "upgrade",      "description": "Upgrade Claude Code" },
    { "command": "ide",          "description": "IDE integration status" },
    { "command": "chrome",       "description": "Toggle Chrome integration" },
    { "command": "resume",       "description": "Resume a previous conversation" },
    { "command": "rewind",       "description": "Rewind conversation" },
    { "command": "loop",         "description": "Auto-loop mode (run repeated checks)" },
    { "command": "schedule",     "description": "Schedule a background agent" },
    { "command": "tasks",        "description": "Show background tasks" },
    { "command": "stats",        "description": "Show stats" },
    { "command": "ultrareview",  "description": "Multi-agent cloud review of branch / PR" },
    { "command": "powerup",      "description": "Powerup mode" },
    { "command": "btw",          "description": "Side-channel comment to assistant" },
    { "command": "think",        "description": "Toggle thinking display" },
    { "command": "screenshot",   "description": "Capture screenshot" }
  ]
}
